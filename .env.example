# Johnson Church of Christ - Accounts Payable
# Copy this file to .env and fill in your values

# === Email / SMTP Settings ===
# Set these to send real approval emails instead of simulation.

SMTP_SERVER=smtp.gmail.com          # or smtp.office365.com, mail.yourchurch.org, etc.
SMTP_PORT=587
SMTP_USERNAME=your-email@yourdomain.com
SMTP_PASSWORD=your-app-password-or-real-password
FROM_EMAIL=ap@johnsoncoc.org        # The "From" address shown in emails

# Optional
# SECRET_KEY=some-long-random-string   # Change this in production!
# PORT=5000
# BASE_URL=https://your-app.onrender.com
# SESSION_COOKIE_SECURE=true           # Force secure session cookies (HTTPS only)
